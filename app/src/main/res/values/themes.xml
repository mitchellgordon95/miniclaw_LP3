<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Minimal, no-ActionBar base theme. The actual UI styling comes from Compose's
         MaterialTheme; this just gives us a black, chromeless window to draw into. -->
    <style name="Theme.Voice" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>
</resources>
