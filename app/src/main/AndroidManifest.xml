<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Lets the accessibility service / wake service bring the app to the foreground (and over
         the lockscreen) from the background. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Earbud-button wake: a mediaPlayback foreground service hosting a MediaSession. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- So we can launch the LightOS launcher for the "Return to home" button. -->
    <queries>
        <package android:name="com.lightos" />
    </queries>

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Voice">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:stateNotNeeded="true"
            android:excludeFromRecents="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|keyboardHidden|screenSize|screenLayout">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Listens for the DJI mic button (a HID VOLUME_UP) system-wide, screen on. It filters
             by input device so only the DJI mic triggers a summon; the phone's own volume rocker
             is left alone. No foreground-service notification required. -->
        <service
            android:name=".SummonService"
            android:exported="false"
            android:label="MiniClaw mic button"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/summon_accessibility_config" />
        </service>

        <!-- Hosts the MediaSession that catches the Bluetooth earbud button while the phone is
             locked/screen-off (the case the DJI volume-up button can't reach). -->
        <service
            android:name=".WakeService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Restarts WakeService after a reboot. -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
